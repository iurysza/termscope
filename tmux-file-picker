def cmd_fallback(args: argparse.Namespace) -> None:
    pane_path = Path(args.pane_path) if args.pane_path else Path.cwd()
    pane_id = args.pane_id or ""
    mode = args.mode
    query = args.query
    line = args.line or ""
    source_pane_path = resolve_source_pane_path(pane_path, pane_id)
    search_root = find_search_root(source_pane_path)

    state = DebugState(
        pane_path=str(pane_path),
        pane_id=pane_id,
        source_pane_path=str(source_pane_path),
        search_root=str(search_root),
        mode=mode,
        line=line,
        query=query,
    )

    selected = run_fallback_picker(search_root, query)
    if not selected:
        debug_dump(state)
        return

    resolved = resolve_existing_path(selected, source_pane_path, search_root)
    if not resolved:
        resolved = search_root / selected

    state.selection = selected
    state.resolved_path = str(resolved)
    debug_dump(state)
    copy_to_clipboard(str(resolved))

    if mode == "default":
        open_with_default_app(resolved)
    else:
        open_in_nvim_split(resolved, line, source_pane_path, pane_id)


def cmd_links(args: argparse.Namespace) -> None:
    pane_path = Path(args.pane_path) if args.pane_path else Path.cwd()
    pane_id = args.pane_id or ""

    screen_text = capture_pane_text(pane_id)
    screen_text = strip_ansi(screen_text)
    candidates = extract_visible_links(screen_text)

    state = DebugState(
        pane_path=str(pane_path),
        pane_id=pane_id,
        source_pane_path=str(pane_path),
        search_root="",
        candidate_count=len(candidates),
        screen_line_count=len(screen_text.splitlines()),
        visible_only=True,
        screen_text=screen_text,
        candidates=candidates,
    )

    real_candidates = [c for c in candidates if c.strip()]
    if not real_candidates:
        subprocess.run(
            ["tmux", "display-message", "No visible links found"],
            check=False,
        )
        log_event("links_empty", pane_id=pane_id)
        debug_dump(state)
        return

    log_event(
        "links_start",
        pane_path=str(pane_path),
        pane_id=pane_id,
        candidate_count=len(real_candidates),
    )

    fzf_result = run_fzf_links(real_candidates)
    if fzf_result is None:
        log_event("links_cancel_or_empty", pane_id=pane_id, candidate_count=len(real_candidates))
        debug_dump(state)
        return

    state.query = fzf_result.query
    state.key = fzf_result.key
    state.selection = fzf_result.selection

    selection = fzf_result.selection
    if not selection:
        debug_dump(state)
        return

    state.resolved_path = selection
    state.mode = "url"
    copy_to_clipboard(selection)
    debug_dump(state)

    if fzf_result.key == "ctrl-y":
        subprocess.run(
            ["tmux", "display-message", "Link copied to clipboard"],
            check=False,
        )
        return

    open_with_default_app(selection)


