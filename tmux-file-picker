def main() -> None:
    parser = argparse.ArgumentParser(prog="tmux-file-picker")
    subparsers = parser.add_subparsers(dest="command", required=True)

    pick_parser = subparsers.add_parser("pick")
    pick_parser.add_argument("--pane-path", required=True)
    pick_parser.add_argument("--pane-id", required=True)

    open_parser = subparsers.add_parser("open")
    open_parser.add_argument("--mode", choices=["nvim", "default"], required=True)
    open_parser.add_argument("--pane-path", required=True)
    open_parser.add_argument("--pane-id", required=True)

    fallback_parser = subparsers.add_parser("fallback")
    fallback_parser.add_argument("--mode", choices=["nvim", "default"], required=True)
    fallback_parser.add_argument("--pane-path", required=True)
    fallback_parser.add_argument("--pane-id", required=True)
    fallback_parser.add_argument("--query", required=True)
    fallback_parser.add_argument("--line", default="")

    scan_parser = subparsers.add_parser("scan")
    scan_parser.add_argument("--pane-path", required=True)
    scan_parser.add_argument("--pane-id", required=True)

    links_parser = subparsers.add_parser("links")
    links_parser.add_argument("--pane-path", required=True)
    links_parser.add_argument("--pane-id", required=True)

    args = parser.parse_args()
    log_event("start", command=args.command, argv=sys.argv[1:])

    if args.command == "pick":
        cmd_pick(args)
    elif args.command == "open":
        cmd_open(args)
    elif args.command == "fallback":
        cmd_fallback(args)
    elif args.command == "scan":
        cmd_scan(args)
    elif args.command == "links":
        cmd_links(args)


if __name__ == "__main__":
    try:
        main()
    except Exception as exc:
        log_event("crash", error=str(exc), traceback=traceback.format_exc(), argv=sys.argv[1:])
        raise
