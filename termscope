        debug_dump(state)
        return

    state.resolved_path = selection
    state.mode = "url"
    copy_to_clipboard(selection)
    debug_dump(state)

    if picker_result.key == "ctrl-y":
        show_message("Link copied to clipboard", backend)
        return

