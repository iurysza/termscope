def debug_dump(state: DebugState) -> None:
    debug_dir = os.environ.get("TERMSCOPE_DEBUG_DIR", "")
    if not debug_dir:
        return

    run_id = f"run-{datetime.now().strftime('%Y%m%d-%H%M%S')}-{uuid.uuid4().hex[:6]}"
    run_dir = Path(debug_dir) / run_id
    run_dir.mkdir(parents=True, exist_ok=True)
    run_dir.chmod(0o700)

    (run_dir / "screen.txt").write_text(state.screen_text, encoding="utf-8")
    (run_dir / "files.txt").write_text("\n".join(state.indexed_files), encoding="utf-8")
    (run_dir / "candidates.txt").write_text("\n".join(state.candidates), encoding="utf-8")

    picker_data = {
        "query": state.query,
        "key": state.key,
        "selection": state.selection,
    }
    (run_dir / "picker.json").write_text(json.dumps(picker_data, indent=2), encoding="utf-8")

    decision = {
        "pane_path": state.pane_path,
        "pane_id": state.pane_id,
        "source_pane_path": state.source_pane_path,
        "search_root": state.search_root,
        "indexed_count": state.indexed_count,
        "candidate_count": state.candidate_count,
        "screen_line_count": state.screen_line_count,
        "visible_only": state.visible_only,
        "query": state.query,
        "key": state.key,
        "selection": state.selection,
        "resolved_path": state.resolved_path,
        "mode": state.mode,
        "line": state.line,
    }
    (run_dir / "decision.json").write_text(json.dumps(decision, indent=2), encoding="utf-8")

    for f in run_dir.iterdir():
        f.chmod(0o600)

    print(f"termscope debug: {run_dir}", file=sys.stderr)


