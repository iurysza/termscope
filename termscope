def resolve_source_pane_path(
    pane_path: Path, pane_id: str, backend: MultiplexerBackend | None = None
) -> Path:
    if backend is None:
        backend = detect_backend(pane_id)
    return backend.resolve_source_pane_path(pane_path, pane_id)


def find_search_root(pane_path: Path) -> Path:
    try:
        result = subprocess.run(
            ["git", "-C", str(pane_path), "rev-parse", "--show-toplevel"],
            text=True,
            capture_output=True,
            check=False,
        )
        p = result.stdout.strip()
        if p and Path(p).is_dir():
            return Path(p)
    except FileNotFoundError:
        pass
    return pane_path


