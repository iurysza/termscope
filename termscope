def capture_pane_text(pane_id: str, backend: MultiplexerBackend | None = None) -> str:
    if backend is None:
        backend = detect_backend(pane_id)
    return backend.capture_pane_text(pane_id)


# --------------------------------------------------------------------------- #
# Text cleaning
# --------------------------------------------------------------------------- #

ANSI_RE = re.compile(r"\x1b\][^\x07]*(?:\x07|\x1b\\)")
ANSI_CSI_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]")


def strip_ansi(text: str) -> str:
    text = ANSI_RE.sub("", text)
    text = ANSI_CSI_RE.sub("", text)
    return text


def clean_visible_line(line: str) -> str:
    s = line.strip()
    s = re.sub(r"^(?:[-*+>•]+|\d+[.)])\s*", "", s)
    s = s.strip().strip("`'\"").strip()
    s = s.rstrip(".,;:")
    return s.strip()


# --------------------------------------------------------------------------- #
# Link extraction
# --------------------------------------------------------------------------- #

URL_RE = re.compile(r"https?://[^\s<>\[\]{}|\\^`\"]+", re.IGNORECASE)
MARKDOWN_LINK_RE = re.compile(r"!?\[[^\]]*\]\(([^)]+)\)")
ANGLE_LINK_RE = re.compile(r"<(https?://[^>]+)>", re.IGNORECASE)


def _clean_url_trailing_punctuation(url: str) -> str:
    while url and url[-1] in ",;:!?.":
        url = url[:-1]
    while url.endswith(")") and "(" not in url:
        url = url[:-1]
    while url.endswith(">") and "<" not in url:
        url = url[:-1]
    return url.strip().strip("'\"")


def sort_items(items: dict[str, int], sort: str = "appearance") -> list[str]:
    """Return dictionary keys sorted by appearance order or alphabetically."""
    if sort == "alpha":
        return sorted(items.keys(), key=lambda s: s.lower())
    return [
        item for item, _ in sorted(items.items(), key=lambda item: (item[1], item[0].lower()))
    ]


def extract_visible_links(screen_text: str, sort: str = "appearance") -> list[str]:
    raw_lines = screen_text.splitlines()
    matches: dict[str, int] = {}

    def add(url: str, pos: int) -> None:
        url = _clean_url_trailing_punctuation(url)
        if not url:
            return
        if url not in matches:
            matches[url] = pos

    for i, line in enumerate(raw_lines):
        for m in MARKDOWN_LINK_RE.finditer(line):
            add(m.group(1), i)
        for m in ANGLE_LINK_RE.finditer(line):
            add(m.group(1), i)
        for m in URL_RE.finditer(line):
            add(m.group(0), i)

    return sort_items(matches, sort)


# --------------------------------------------------------------------------- #
# File indexing
# --------------------------------------------------------------------------- #

def list_repo_files(search_root: Path) -> list[str]:
    # Skip home directory — too large to index.
    home = Path.home()
    try:
        search_root.resolve().relative_to(home.resolve())
        if search_root.resolve() == home.resolve():
            return []
    except ValueError:
        pass  # Not under home, ok to scan

    try:
        result = subprocess.run(
            [
                "fd",
                "--type",
                "f",
                "--type",
                "d",
                "--hidden",
                "--follow",
                "--exclude",
                ".git",
                ".",
            ],
            cwd=search_root,
            text=True,
            capture_output=True,
            timeout=5,  # Don't hang on huge directories
            check=False,
        )
    except FileNotFoundError:
        return []
    except subprocess.TimeoutExpired:
        return []
    if result.returncode != 0:
        return []
    lines = [ln.rstrip("\n") for ln in result.stdout.splitlines() if ln.rstrip("\n")]
    # Bound scan cost and picker startup time on very large repositories.
    return lines[:5000]


# --------------------------------------------------------------------------- #
# Candidate extraction
# --------------------------------------------------------------------------- #

def extract_visible_candidates(
    screen_text: str,
    repo_paths: list[str],
    search_root: Path,
    pane_path: Path,
    sort: str = "appearance",
) -> list[str]:
    home = Path.home()
    raw_lines = screen_text.splitlines()

    lines: list[str] = []
    line_pos: dict[str, int] = {}

    for i, raw in enumerate(raw_lines):
        variants = {raw.strip(), clean_visible_line(raw)}
        variants.update(
            m.group(1).strip() for m in re.finditer(r"[`'\"]([^`'\"]+)[`'\"]", raw)
        )
        for v in variants:
            if v and v not in line_pos:
                line_pos[v] = i
                lines.append(v)

    joined = "\n".join(lines)
    matches: dict[str, int] = {}

    def add(display: str, pos: int) -> None:
        if not display:
            return
        prev = matches.get(display)
        if prev is None or pos < prev:
            matches[display] = pos

    def home_display(abs_path: str) -> str:
        if abs_path == str(home):
            return "~"
        p = Path(abs_path)
        try:
            rel = p.relative_to(home)
            return f"~/{rel}"
        except ValueError:
            return abs_path

    def add_resolved(candidate: str, pos: int) -> None:
        c = candidate.strip().strip("`'\"").rstrip(".,;:")
        if not c:
            return

        # Strip line number suffix for existence checking
        base_c = c
        line_num = ""
        line_m = re.match(r'^(.+?):(\d+)(?::\d+)?$', c)
        if line_m:
            base_c = line_m.group(1)
            line_num = line_m.group(2)

        expanded_candidates: list[str] = []
        expanded = os.path.expanduser(base_c)
        if base_c.startswith(("./", "../")):
            expanded_candidates.append(os.path.abspath(os.path.join(pane_path, base_c)))
        elif os.path.isabs(expanded):
            expanded_candidates.append(expanded)
        elif "/" in base_c and "://" not in base_c:
            expanded_candidates.append(os.path.abspath(os.path.join(pane_path, base_c)))
            expanded_candidates.append(os.path.abspath(os.path.join(search_root, base_c)))
        else:
            return

        root_str = str(search_root)
        for expanded in expanded_candidates:
            if not os.path.exists(expanded):
                continue
            if expanded.startswith(root_str + os.sep):
                display = os.path.relpath(expanded, root_str)
            else:
                display = home_display(expanded)
            if line_num:
                display = f"{display}:{line_num}"
            add(display, pos)
            return

    # Existing absolute/~/relative paths visible on screen
    pathish = re.compile(r"(?<!\S)(?:~|/|\./|\.\./)[^\s`'\"<>|]+")
    relative_pathish = re.compile(r"(?<!\S)(?![A-Za-z][A-Za-z0-9+.-]*://)[^\s`'\"<>|]+/[^\s`'\"<>|]+")
    for i, raw in enumerate(raw_lines):
        cleaned = clean_visible_line(raw)
        if cleaned.startswith(("~/", "/", "./", "../")) or ("/" in cleaned and "://" not in cleaned):
            add_resolved(cleaned, i)
        for m in pathish.finditer(raw):
            add_resolved(m.group(0), i)
        for m in relative_pathish.finditer(raw):
            add_resolved(m.group(0), i)

    # Authoritative repo match
    for path in repo_paths:
        base = os.path.basename(path)
        abs_path = os.path.join(str(search_root), path)
        variants = [path, "./" + path, abs_path, home_display(abs_path)]

        if path.endswith(".md"):
            variants.append(path[:-3])
            if base.endswith(".md"):
                variants.append(base[:-3])

        for variant in variants:
            pos = joined.find(variant)
            if pos >= 0:
                after = joined[pos + len(variant):]
                line_m = re.match(r':(\d+)(?::\d+)?', after)
                display = f"{path}:{line_m.group(1)}" if line_m else path
                add(display, pos)
                break

        base_variants = [base]
        if base.endswith(".md"):
            base_variants.append(base[:-3])
        for variant in base_variants:
            if variant in line_pos:
                add(path, line_pos[variant])
                break
            # Also match basename with line suffix (e.g., "main.py:12")
            for line_key, line_idx in line_pos.items():
                if line_key.startswith(variant + ":"):
                    line_m = re.match(rf'{re.escape(variant)}:(\d+)(?::\d+)?', line_key)
                    display = f"{path}:{line_m.group(1)}" if line_m else path
                    add(display, line_idx)
                    break
            else:
                continue
            break

    return sort_items(matches, sort)


# --------------------------------------------------------------------------- #
# Target parsing
# --------------------------------------------------------------------------- #

TARGET_RE = re.compile(r"^(.+?):([0-9]+)(:[0-9]+)?:?$")
TARGET_CTX_RE = re.compile(r"^(.+)-([0-9]+)-$")


def parse_selected_target(text: str) -> ParsedTarget:
    t = text.split("\n", 1)[0].rstrip("\r").strip()
    t = t.strip("`'\"").strip()
    t = t.rstrip(".,;:").strip()
    if not t:
        return ParsedTarget(path="")

    file_target = t
    line_target = ""

    m = TARGET_RE.match(t)
    if m:
        file_target = m.group(1)
        line_target = m.group(2)
    else:
        m = TARGET_CTX_RE.match(t)
        if m:
            file_target = m.group(1)
            line_target = m.group(2)

    return ParsedTarget(path=file_target, line=line_target)


# --------------------------------------------------------------------------- #
# Path resolution
# --------------------------------------------------------------------------- #

def resolve_existing_path(path_text: str, pane_path: Path, search_root: Path) -> Path | None:
    if path_text == "~":
        expanded = Path.home()
        if expanded.exists():
            return expanded
        return None

    if path_text.startswith("~/"):
        expanded = Path.home() / path_text[2:]
        if expanded.exists():
            return expanded
        return None

    if path_text.startswith("/"):
        p = Path(path_text)
        if p.exists():
            return p
        return None

    # Relative: try pane_path first, then search_root
    for base in (pane_path, search_root):
        p = base / path_text
        if p.exists():
            return p

    return None


# --------------------------------------------------------------------------- #
# Television
# --------------------------------------------------------------------------- #

def parse_tv_result(stdout: str, expect_keys: tuple[str, ...]) -> PickerResult:
    """Parse Television's stdout selection protocol.

    Enter prints only the selection. A key supplied through ``--expect`` prints
    the key first, followed by the selection.
    """
    lines = stdout.rstrip("\n").split("\n") if stdout else []
    if not lines:
        return PickerResult()
    if lines[0] in expect_keys:
        return PickerResult(key=lines[0], selection="\n".join(lines[1:]))
    return PickerResult(selection="\n".join(lines))


def _television_cable_dir() -> Path:
    return Path(__file__).resolve().parent / "cable"


def encode_candidate(candidate: str) -> str:
    """Return a shell-safe opaque id for a Television candidate."""
    return base64.urlsafe_b64encode(candidate.encode("utf-8")).decode("ascii").rstrip("=")


def decode_candidate(encoded: str) -> str:
    """Restore a candidate id emitted by the bundled Television channels."""
    if not encoded or not re.fullmatch(r"[A-Za-z0-9_-]+", encoded):
        raise ValueError("invalid Television candidate id")
    padding = "=" * (-len(encoded) % 4)
    try:
        return base64.urlsafe_b64decode(encoded + padding).decode("utf-8")
    except (binascii.Error, UnicodeDecodeError) as exc:
        raise ValueError("invalid Television candidate id") from exc


def _write_candidate_file(path: Path, candidates: list[str]) -> None:
    records = [f"{encode_candidate(candidate)}\t{candidate}" for candidate in candidates]
    content = "\n".join(records)
    if records:
        content += "\n"
    path.write_text(content, encoding="utf-8")


def _picker_error(message: str) -> None:
    print(f"termscope: {message}", file=sys.stderr)
    herdr = os.environ.get("HERDR_BIN_PATH")
    if herdr:
        subprocess.run(
            [herdr, "notification", "show", f"Termscope: {message}"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )


def _television_is_supported(television: str) -> bool:
    try:
        result = subprocess.run(
            [television, "--version"],
            text=True,
            capture_output=True,
            check=False,
            timeout=2,
        )
    except (OSError, subprocess.TimeoutExpired):
        return False
    if result.returncode != 0:
        return False
    match = re.search(r"\btelevision\s+(\d+)\.(\d+)\.(\d+)", result.stdout)
    return bool(match and tuple(map(int, match.groups())) >= (0, 15, 0))


def _run_tv(
    candidates: list[str],
    header: str,
    expect_keys: tuple[str, ...],
    sort: str = "appearance",
    cwd: Path | None = None,
    preview: bool = True,
) -> PickerResult | None:
    input_lines = [candidate for candidate in candidates if candidate.strip()]
    if not input_lines:
        return None

    television = shutil.which("tv")
    if not television:
        _picker_error("television (tv) not found")
        raise SystemExit(1)
    if not _television_is_supported(television):
        _picker_error("Television 0.15+ is required")
        raise SystemExit(1)

    cwd = cwd or Path.cwd()
    with tempfile.TemporaryDirectory(prefix="termscope-tv-") as temp_dir:
        temp_path = Path(temp_dir)
        appearance_path = temp_path / "appearance.txt"
        alpha_path = temp_path / "alpha.txt"
        _write_candidate_file(appearance_path, input_lines)
        _write_candidate_file(alpha_path, sorted(input_lines, key=str.lower))

        env = os.environ.copy()
        env.update(
            {
                "TERMSCOPE_APPEARANCE_CANDIDATES": str(appearance_path),
                "TERMSCOPE_ALPHA_CANDIDATES": str(alpha_path),
                "TERMSCOPE_PANE_PATH": str(cwd),
                "TERMSCOPE_PYTHON": sys.executable,
                "TERMSCOPE_SCRIPT": str(Path(__file__).resolve()),
            }
        )

        command = [
            television,
            "--cable-dir",
            str(_television_cable_dir()),
            "--no-remote",
            "--no-help-panel",
            "--input-header",
            header,
        ]
        if expect_keys:
            command.extend(["--expect", ";".join(expect_keys)])
        if not preview:
            command.append("--no-preview")
        command.append(f"termscope-{sort}")

        try:
            result = subprocess.run(
                command,
                cwd=cwd,
                env=env,
                text=True,
                stdout=subprocess.PIPE,
                check=False,
            )
        except FileNotFoundError:
            _picker_error("television (tv) not found")
            raise SystemExit(1)

    if result.returncode != 0:
        _picker_error(f"Television failed with status {result.returncode}")
        raise SystemExit(result.returncode)

    if result.stdout == "":
        return PickerResult()
    picker_result = parse_tv_result(result.stdout, expect_keys)
    if not picker_result.selection:
        _picker_error("Television returned an invalid selection")
        raise SystemExit(1)
    try:
        picker_result.selection = decode_candidate(picker_result.selection)
    except ValueError:
        _picker_error("Television returned an invalid selection")
        raise SystemExit(1)
    if picker_result.selection not in input_lines:
        _picker_error("Television returned an unknown selection")
        raise SystemExit(1)
    return picker_result


def display_path(path: Path) -> str:
    try:
        relative = path.relative_to(Path.home())
    except ValueError:
        return str(path)
    return "~" if relative == Path(".") else f"~/{relative}"


def run_tv_visible(
    candidates: list[str], search_root: Path, sort: str = "appearance"
) -> PickerResult | None:
    return _run_tv(
        candidates,
        f"Files — {display_path(search_root)}",
        ("ctrl-o", "ctrl-y"),
        sort=sort,
        cwd=search_root,
    )


def run_tv_links(
    candidates: list[str], pane_path: Path, sort: str = "appearance"
) -> PickerResult | None:
    return _run_tv(
        candidates,
        "Visible links — Enter opens · Ctrl-Y copies · Ctrl-S changes order",
        ("ctrl-y",),
        sort=sort,
        cwd=pane_path,
        preview=False,
    )


def sort_file_list(files: list[str], sort: str = "appearance") -> list[str]:
    """Sort a plain file list alphabetically or leave it as-is."""
    if sort == "alpha":
        return sorted(files, key=lambda s: s.lower())
    return files


def run_tv_full_repo(search_root: Path, sort: str = "appearance") -> PickerResult | None:
    """Show all repo files when no visible candidate exists."""
    files = list_repo_files(search_root)
    if not files:
        return None
    return _run_tv(
        files,
        f"All files — {display_path(search_root)}",
        ("ctrl-o", "ctrl-y"),
        sort=sort,
        cwd=search_root,
    )


