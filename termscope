def choose_default_opener() -> list[str]:
    env = os.environ.get("TERMSCOPE_OPENER", "")
    if env:
        return shlex.split(env)

    if sys.platform == "darwin":
        return ["open"]

    # WSL detection
    try:
        with open("/proc/version", "r") as f:
            if "microsoft" in f.read().lower():
                return ["wslview"]
    except FileNotFoundError:
        pass
    if os.environ.get("WSL_DISTRO_NAME"):
        return ["wslview"]

    return ["xdg-open"]


def _check_opener(opener: list[str]) -> None:
    if not opener:
        sys.exit("termscope: no opener configured")
    exe = shutil.which(opener[0])
    if not exe:
        sys.exit(f"termscope: opener not found: {opener[0]}")


def open_with_default_app(target: str | Path) -> NoReturn:
    opener = choose_default_opener()
    _check_opener(opener)
    os.execvp(opener[0], opener + [str(target)])


def open_url(url: str) -> NoReturn:
    """Open a URL with the configured/default opener."""
    open_with_default_app(url)


def open_in_nvim_split(
    path: Path,
    line: str,
    pane_path: Path,
    pane_id: str,
    backend: MultiplexerBackend | None = None,
) -> NoReturn:
    if backend is None:
        backend = detect_backend(pane_id)
    backend.open_in_nvim_split(path, line, pane_path, pane_id)


def copy_to_clipboard(text: str) -> None:
    try:
        subprocess.run(["pbcopy"], input=text, text=True, check=False)
    except FileNotFoundError:
        pass


def send_annotate_command(
    pane_id: str, file_path: str, backend: MultiplexerBackend | None = None
) -> None:
