# --------------------------------------------------------------------------- #
# Multiplexer backend abstraction
# --------------------------------------------------------------------------- #

class MultiplexerBackend(ABC):
    """Abstracts tmux- and herdr-specific control commands."""

    @property
    @abstractmethod
    def name(self) -> str:
        ...

    @abstractmethod
    def resolve_source_pane_path(self, pane_path: Path, pane_id: str) -> Path:
        """Return the best cwd for the source pane."""
        ...

    @abstractmethod
    def capture_pane_text(self, pane_id: str) -> str:
        """Return the currently visible text from the source pane."""
        ...

    @abstractmethod
    def open_in_nvim_split(
        self, path: Path, line: str, pane_path: Path, pane_id: str
    ) -> NoReturn:
        """Open path in a new nvim split next to the source pane, then exit."""
        ...

    @abstractmethod
    def send_annotate_command(self, pane_id: str, file_path: str) -> None:
        """Request Plannotator through the source pane's active interface."""
        ...

    @abstractmethod
    def show_message(self, message: str) -> None:
        """Show a short, non-blocking message to the user."""
        ...


class TmuxBackend(MultiplexerBackend):
    @property
    def name(self) -> str:
        return "tmux"

    def resolve_source_pane_path(self, pane_path: Path, pane_id: str) -> Path:
        if pane_id:
            try:
                result = subprocess.run(
                    ["tmux", "display-message", "-p", "-t", pane_id, "#{pane_current_path}"],
                    text=True,
                    capture_output=True,
                    check=False,
                )
                p = result.stdout.strip()
                if p and Path(p).is_dir():
                    return Path(p)
            except FileNotFoundError:
                pass
        return pane_path

    def capture_pane_text(self, pane_id: str) -> str:
        cmd = ["tmux", "capture-pane", "-pJ"]

        # If the source pane is in copy mode, capture the scrolled viewport
        # instead of the live bottom content. This only works if the binding does
        # not cancel copy mode before launching this script.
        if pane_id:
            mode_result = subprocess.run(
                ["tmux", "display-message", "-p", "-t", pane_id, "#{pane_in_mode}"],
                text=True,
                capture_output=True,
                check=False,
            )
            if mode_result.stdout.strip() == "1":
                scroll_result = subprocess.run(
                    ["tmux", "display-message", "-p", "-t", pane_id, "#{scroll_position}"],
                    text=True,
                    capture_output=True,
                    check=False,
                )
                height_result = subprocess.run(
                    ["tmux", "display-message", "-p", "-t", pane_id, "#{pane_height}"],
                    text=True,
                    capture_output=True,
                    check=False,
                )
                scroll_str = scroll_result.stdout.strip()
                height_str = height_result.stdout.strip()
                if scroll_str.isdigit() and height_str.isdigit():
                    scroll = int(scroll_str)
                    height = int(height_str)
                    if scroll > 0 and height > 0:
                        if scroll < height:
                            end = str(height - scroll - 1)
                        else:
                            end = f"-{scroll - height + 1}"
                        cmd.extend(["-S", f"-{scroll}", "-E", end])
                        log_event(
                            "capture_scrollback_viewport",
                            pane_id=pane_id,
                            scroll_position=scroll,
                            pane_height=height,
                            start=f"-{scroll}",
                            end=end,
                        )

            cmd.extend(["-t", pane_id])

        result = subprocess.run(cmd, text=True, capture_output=True, check=False)
        return result.stdout

    def open_in_nvim_split(
        self, path: Path, line: str, pane_path: Path, pane_id: str
    ) -> NoReturn:
        cmd = ["nvim", f"+{line}", str(path)] if line else ["nvim", str(path)]
        inner = shlex.join(cmd)

        tmux_cmd = ["tmux", "split-window"]
        if pane_id:
            tmux_cmd += ["-t", pane_id]
        tmux_cmd += ["-h", "-c", str(pane_path), inner]

        os.execvp(tmux_cmd[0], tmux_cmd)

    def send_annotate_command(self, pane_id: str, file_path: str) -> None:
        # Cancel copy mode so the command reaches the source application.
        pane_result = subprocess.run(
            [
                "tmux",
                "display-message",
                "-p",
                "-t",
                pane_id,
                "#{pane_in_mode}\t#{pane_current_command}",
            ],
            text=True,
            capture_output=True,
            check=False,
        )
        fields = pane_result.stdout.rstrip("\n").split("\t", 1)
        in_copy_mode = fields[0] == "1"
        current_command = fields[1].lower() if len(fields) == 2 else ""
        if in_copy_mode:
            subprocess.run(
                ["tmux", "send-keys", "-t", pane_id, "-X", "cancel"],
                check=False,
            )

        quoted_path = shlex.quote(file_path)
        agent_commands = {"pi", "opencode", "claude", "codex"}
        if not current_command or current_command in agent_commands:
            cmd_text = f"/plannotator-annotate {quoted_path}"
        else:
            cmd_text = f"plannotator annotate {quoted_path}"
        subprocess.run(
            ["tmux", "send-keys", "-t", pane_id, "-l", cmd_text],
            check=False,
        )
        subprocess.run(
            ["tmux", "send-keys", "-t", pane_id, "Enter"],
            check=False,
        )
        self.show_message("Plannotator annotation requested")

    def show_message(self, message: str) -> None:
        subprocess.run(
            ["tmux", "display-message", message],
            check=False,
        )


class HerdrBackend(MultiplexerBackend):
    @property
    def name(self) -> str:
        return "herdr"

    def _herdr_bin(self) -> str:
        return os.environ.get("HERDR_BIN_PATH") or shutil.which("herdr") or "herdr"

    def resolve_source_pane_path(self, pane_path: Path, pane_id: str) -> Path:
        if not pane_id:
            return pane_path
        try:
            result = subprocess.run(
                [self._herdr_bin(), "pane", "get", pane_id],
                text=True,
                capture_output=True,
                check=False,
            )
            if result.returncode != 0:
                return pane_path
            data = json.loads(result.stdout)
            p = data.get("result", {}).get("pane", {}).get("cwd", "")
            if p and Path(p).is_dir():
                return Path(p)
        except (FileNotFoundError, json.JSONDecodeError):
            pass
        return pane_path

    def capture_pane_text(self, pane_id: str) -> str:
        result = subprocess.run(
            [self._herdr_bin(), "pane", "read", pane_id, "--source", "visible"],
            text=True,
            capture_output=True,
            check=False,
        )
        return result.stdout

    def open_in_nvim_split(
        self, path: Path, line: str, pane_path: Path, pane_id: str
    ) -> NoReturn:
        herdr = self._herdr_bin()
        result = subprocess.run(
            [herdr, "pane", "split", pane_id, "--direction", "right", "--cwd", str(pane_path)],
            text=True,
            capture_output=True,
            check=False,
        )
        if result.returncode != 0:
            print(f"termscope: herdr pane split failed: {result.stderr}", file=sys.stderr)
            sys.exit(1)

        try:
            data = json.loads(result.stdout)
            new_pane_id = data["result"]["pane"]["pane_id"]
        except (json.JSONDecodeError, KeyError) as exc:
            print(f"termscope: could not parse herdr split response: {exc}", file=sys.stderr)
            sys.exit(1)

        nvim_cmd = f"nvim +{line} {shlex.quote(str(path))}" if line else f"nvim {shlex.quote(str(path))}"
        subprocess.run(
            [herdr, "pane", "run", new_pane_id, nvim_cmd],
            check=False,
        )
        sys.exit(0)

    def send_annotate_command(self, pane_id: str, file_path: str) -> None:
        herdr = self._herdr_bin()
        quoted_path = shlex.quote(file_path)
        source_agent = os.environ.get("SOURCE_PANE_AGENT")
        if source_agent is None or source_agent:
            command = f"/plannotator-annotate {quoted_path}"
        else:
            command = f"plannotator annotate {quoted_path}"
        subprocess.run(
            [herdr, "pane", "run", pane_id, command],
            check=False,
        )
        self.show_message("Plannotator annotation requested")

    def show_message(self, message: str) -> None:
        subprocess.run(
            [self._herdr_bin(), "notification", "show", message],
            check=False,
        )


def detect_backend(pane_id: str) -> MultiplexerBackend:
    """Pick a backend from the pane id shape."""
    if pane_id and re.match(r"^(?:w[0-9A-Za-z]+:p[0-9A-Za-z]+|\d+-\d+)$", pane_id):
        return HerdrBackend()
    return TmuxBackend()


def choose_backend(multiplexer: str, pane_id: str) -> MultiplexerBackend:
    if multiplexer == "tmux":
        return TmuxBackend()
    if multiplexer == "herdr":
        return HerdrBackend()
    return detect_backend(pane_id)


# --------------------------------------------------------------------------- #
# Logging
# --------------------------------------------------------------------------- #

def log_path() -> Path:
    configured = os.environ.get("TERMSCOPE_LOG")
    if configured:
        return Path(configured)
    cache_dir = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache"))
    return cache_dir / "termscope" / "termscope.log"


def log_event(event: str, **data: object) -> None:
    try:
        path = log_path()
        path.parent.mkdir(parents=True, exist_ok=True)
        path.parent.chmod(0o700)
        payload = {
            "time": datetime.now().isoformat(timespec="seconds"),
            "event": event,
            **data,
        }
        with path.open("a", encoding="utf-8") as f:
            f.write(json.dumps(payload, default=str) + "\n")
        path.chmod(0o600)
    except Exception:
        pass


